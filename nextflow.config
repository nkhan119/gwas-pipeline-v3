// ================================================================
//  nextflow.config — GWAS Pipeline CDC 1.0.0
//  Author : Nadeem Khan, Bioinformatician, INRS-CAFSB
//  GitHub : github.com/nkhan119
// ================================================================

manifest {
    name            = 'gwas-pipeline'
    author          = 'Nadeem Khan, INRS-CAFSB'
    description     = 'Two-cohort GWAS pipeline: QC → PCA → REGENIE → HTML report'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
    mainScript      = 'main.nf'
    homePage        = 'https://github.com/nkhan119'
}

// ── Parameters ─────────────────────────────────────────────────
params {
    // ── Input paths ──────────────────────────────────────────────
    // Directory containing Cohort_A.bed/.bim/.fam and Cohort_B.bed/.bim/.fam
    // ═══════════════════════════════════════════════════════════════
    // EDIT THIS ONE PATH — everything else derives from it
    // Run `pwd` inside your 1000G_phase3_common_norel directory to confirm
    // ═══════════════════════════════════════════════════════════════
    base_dir       = "/home/nadeem/Downloads/1000G_phase3_common_norel"

    // Derived paths — no need to edit these
    raw_dir        = "${params.base_dir}/GWAS_analysis"
    pca_dir        = "${params.base_dir}/GWAS_analysis/pca"
    pheno_dir      = "${params.base_dir}/GWAS_analysis"
    population_file= "${params.base_dir}/GWAS_analysis/sample_populations.tsv"
    ref_bfile      = "${params.base_dir}/1000G_phase3_common_norel"

    // Cohort names — must match bed/bim/fam filenames in raw_dir/Cohort_*/
    cohorts        = "Cohort_A,Cohort_B"

    // ── Output ────────────────────────────────────────────────────
    out_dir        = "${projectDir}/results"

    // ── Traits ───────────────────────────────────────────────────
    quant_traits   = "ldl_cholesterol,bmi,crp_log,height_cm"
    binary_traits  = "cad,t2d,hypertension"

    // ── QC thresholds ────────────────────────────────────────────
    maf            = 0.01
    hwe            = 1e-6
    geno           = 0.02
    mind           = 0.02
    het_sd         = 3

    // ── LD pruning ────────────────────────────────────────────────
    prune_win      = 1000
    prune_step     = 100
    prune_r2       = 0.1

    // ── PCA ──────────────────────────────────────────────────────
    n_pcs          = 20

    // ── REGENIE ──────────────────────────────────────────────────
    step1_bsize    = 1000
    step2_bsize    = 400
    firth_pthresh  = 0.01

    // ── Phenotypes ───────────────────────────────────────────────
    // Set to true to use existing phenotypes.tsv / covariates.tsv
    // already present in raw_dir/Cohort_*/
    // Set to false to simulate phenotypes from scratch via PCA
    use_existing_pheno = true

    // ── Skip flags ────────────────────────────────────────────────
    // Use these when stages have already been completed
    // Example: all stages done → --skip_qc --skip_pca --skip_regenie
    skip_qc        = false
    skip_pca       = false
    skip_regenie   = false
    skip_report    = false

    // ── Compute ──────────────────────────────────────────────────
    threads        = 16

    // Phenotype/covariate directory (defaults to raw_dir)
    pheno_dir      = "/home/nadeem/Downloads/1000G_phase3_common_norel/GWAS_analysis"

    // Population annotation file (IID + Population + SuperPop columns)
    // Set to empty string "" to skip fine-grained PCA colouring
    population_file = "/home/nadeem/Downloads/1000G_phase3_common_norel/GWAS_analysis/sample_populations.tsv"

    // ── Report metadata ──────────────────────────────────────────
    author         = "Nadeem Khan"
    institute      = "INRS-Centre Armand-Frappier Sante-Biotechnologie, Laval, QC, Canada"
    affiliation    = "Bioinformatician"
    github         = "github.com/nkhan119"
}

// ── Process defaults ───────────────────────────────────────────
process {
    errorStrategy = { task.exitStatus in [130,137,140] ? 'retry' : 'finish' }
    maxRetries    = 3
    conda         = "${projectDir}/envs/gwas_env.yaml"

    withLabel: 'tiny'   { cpus = 2;  memory = { 4.GB  * task.attempt }; time = '30m' }
    withLabel: 'small'  { cpus = 4;  memory = { 8.GB  * task.attempt }; time = '2h'  }
    withLabel: 'medium' { cpus = 8;  memory = { 16.GB * task.attempt }; time = '6h'  }
    withLabel: 'large'  { cpus = 16; memory = { 32.GB * task.attempt }; time = '12h' }
    withLabel: 'xlarge' { cpus = 16; memory = { 64.GB * task.attempt }; time = '24h' }

    withName: 'REGENIE_STEP1' { cpus = 16; memory = { 48.GB * task.attempt }; time = '16h' }
    withName: 'REGENIE_STEP2' { cpus = 16; memory = { 32.GB * task.attempt }; time = '10h' }
    withName: 'GENERATE_FIGURES'    { cpus = 4;  memory = { 16.GB * task.attempt }; time = '2h'  }
    withName: 'GWAS_REPORT'   { cpus = 2;  memory = { 8.GB  * task.attempt }; time = '1h'  }
}

// ── Profiles ───────────────────────────────────────────────────
profiles {

    // Local workstation (Precision-5820-Tower)
    local {
        process.executor = 'local'
        executor { cpus = 16; memory = '64 GB' }
        params.threads = 16
    }

    // Compute Canada Narval
    narval {
        process.executor       = 'slurm'
        process.clusterOptions = '--account=def-fveyrier_cpu'
        executor {
            queueSize       = 100
            pollInterval    = '30 sec'
            submitRateLimit = '10/1min'
        }
        process {
            withLabel: 'tiny'   { queue = 'def-fveyrier_cpu'; time = '1h'  }
            withLabel: 'small'  { queue = 'def-fveyrier_cpu'; time = '4h'  }
            withLabel: 'medium' { queue = 'def-fveyrier_cpu'; time = '8h'  }
            withLabel: 'large'  { queue = 'def-fveyrier_cpu'; time = '16h' }
            withLabel: 'xlarge' { queue = 'def-fveyrier_cpu'; time = '24h' }
            withName: 'REGENIE_STEP1' { queue = 'def-fveyrier_cpu'; cpus = 32; memory = { 64.GB * task.attempt }; time = '24h' }
            withName: 'REGENIE_STEP2' { queue = 'def-fveyrier_cpu'; cpus = 32; memory = { 48.GB * task.attempt }; time = '16h' }
        }
        params.threads = 32
    }

    conda {
        conda.enabled  = true
        conda.useMamba = false
    }

    // Quick smoke-test
    test {
        params.step1_bsize = 100
        params.step2_bsize = 100
        params.n_pcs       = 5
        params.cohorts     = "Cohort_A"
        process.memory     = '8 GB'
        process.time       = '1h'
    }
}

conda.enabled = true

// ── Execution reports ───────────────────────────────────────────
def ts = new java.text.SimpleDateFormat("yyyyMMdd_HHmm").format(new Date())

trace    { enabled = true; file = "${params.out_dir}/logs/trace_${ts}.txt";    overwrite = true; fields = 'task_id,name,status,exit,realtime,cpus,%cpu,memory,%mem,rss' }
report   { enabled = true; file = "${params.out_dir}/logs/nf_report_${ts}.html"; overwrite = true }
timeline { enabled = true; file = "${params.out_dir}/logs/timeline_${ts}.html"; overwrite = true }
dag      { enabled = true; file = "${params.out_dir}/logs/dag.svg";            overwrite = true }
